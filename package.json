{
  "name": "unicode-shield",
  "version": "0.1.0",
  "description": "Detect and sanitize dangerous Unicode in user-supplied text: bidi spoofing (Trojan Source), invisible characters, and Unicode Tag prompt-injection payloads, without breaking real RTL text or emoji.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "unicode",
    "security",
    "bidi",
    "trojan-source",
    "sanitize",
    "rtl",
    "prompt-injection",
    "spoofing",
    "confusables"
  ],
  "license": "MIT",
  "author": "Abdelrahman Youssef",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/a-y-ibrahim/unicode-shield.git"
  },
  "bugs": {
    "url": "https://github.com/a-y-ibrahim/unicode-shield/issues"
  },
  "homepage": "https://github.com/a-y-ibrahim/unicode-shield#readme",
  "overrides": {
    "esbuild": ">=0.28.1"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "eslint": "^10.6.0",
    "tsup": "^8.0.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
